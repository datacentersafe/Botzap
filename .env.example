# Renomeie para .env e preencha com seus valores reais.
# NUNCA commite o .env preenchido.

# WhatsApp Cloud API (Meta for Developers)
WA_VERIFY_TOKEN=escolha_uma_string_secreta_qualquer

# Banco de dados
DATABASE_URL=postgres://usuario:senha@localhost:5432/botzap

# Redis
REDIS_URL=redis://localhost:6379

# Porta do servidor
PORT=3000
